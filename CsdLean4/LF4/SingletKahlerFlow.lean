/-! ### `kFlow` preserves the singlet fibre law `őľŌą` -/

/-- **The fibre flow preserves the singlet fibre law.** `kFlow sh` fixes the base
ray (so it preserves the Dirac `őī_{[singlet]}` on `‚Ąā‚Ąô¬≥`) and translates the `T¬≤`
fibre (so it preserves the Haar volume there). This is the singlet analogue of
`kFlow_measurePreserving`, and the genuine Liouville content that makes `ő¶`
load-bearing in the frequency capstone below. -/
theorem kFlow_measurePreserving_muPsi (sh : KTorus) :
    MeasurePreserving (kFlow (N := 4) sh) kMuPsi kMuPsi := by
  have h1 : MeasurePreserving (fun x : AddCircle (1 : ‚ĄĚ) => sh.1 + x)
      (volume : Measure (AddCircle (1 : ‚ĄĚ))) (volume : Measure (AddCircle (1 : ‚ĄĚ))) :=
    measurePreserving_add_left _ sh.1
  have h2 : MeasurePreserving (fun x : AddCircle (1 : ‚ĄĚ) => sh.2 + x)
      (volume : Measure (AddCircle (1 : ‚ĄĚ))) (volume : Measure (AddCircle (1 : ‚ĄĚ))) :=
    measurePreserving_add_left _ sh.2
  have htransl : MeasurePreserving (fun t : KTorus => sh + t)
      (volume : Measure KTorus) (volume : Measure KTorus) := h1.prod h2
  exact (MeasurePreserving.id (Measure.dirac singletRay)).prod htransl

/-! ### The preparation bundle over the `ő¶ ‚Č† id` sector

Each component of `ofK√§hlerPreparation` references the sector only through its
projection `ŌÄ = Prod.fst` and Liouville measure `őľL = kMuL p‚āÄ` ‚ÄĒ both DEFINITIONALLY
equal between `kSectorData` and `kSectorDataFlow` (they differ only in `ő¶`). So the
bridge / preparation / outcome-region proofs port verbatim. -/

/-- The axiom-free measure bridge for the `ő¶ ‚Č† id` sector (`c = 1`, `ŌÄ‚ąóőľL = őľFS`
via `Measure.fst_prod`), identical to `kBridge` ‚ÄĒ the bridge does not see `ő¶`. -/
noncomputable def kBridgeFlow (p‚āÄ : CPN 4) (sh : KTorus) :
    LF2.MeasureBridgeData (kSectorDataFlow p‚āÄ sh) (fubiniStudyMeasure p‚āÄ) where
  is_inv := fun U =>
    ‚ü®(continuous_const_smul U).measurable, fubiniStudyMeasure_smul_invariant U p‚āÄ‚ü©
  c := 1
  bridge_eq := by
    show Measure.map (kSectorDataFlow p‚āÄ sh).ŌÄ
        ((kSectorDataFlow p‚āÄ sh).őľL : Measure (KSigma 4)) = 1 ‚ÄĘ fubiniStudyMeasure p‚āÄ
    rw [one_smul]
    show Measure.map Prod.fst (kMuL p‚āÄ) = fubiniStudyMeasure p‚āÄ
    rw [kMuL, ‚Üź Measure.fst, Measure.fst_prod]

/-- The singlet `PurePreparation` over the `ő¶ ‚Č† id` sector (constant `rep`, Dirac
concentration through `ŌÄ = Prod.fst`), identical to `kPurePrep`. -/
noncomputable def kPurePrepFlow (p‚āÄ : CPN 4) (sh : KTorus) :
    LF2.PurePreparation (kSectorDataFlow p‚āÄ sh) kMuPsi 4 where
  Ōą := singletPsi
  unit_Ōą := singletPsi_norm
  rep := kRep
  hrep_unit := kRep_unit
  hrep_meas := kRep_meas
  ray_point := singletRay
  rep_at_ray := rfl
  push_dirac := by
    show Measure.map (kSectorDataFlow p‚āÄ sh).ŌÄ kMuPsi = Measure.dirac singletRay
    exact kMuPsi_push

/-- The per-sector outcome region over the `ő¶ ‚Č† id` ontic setup: same carved set
`kRegion` as `kOutcomeRegion` (the region is base-flow-agnostic). Its scored event
is `preEvent = kFlow sh ‚ĀĽ¬Ļ' kRegion` ‚ÄĒ the flow enters HERE. -/
noncomputable def kOutcomeRegionFlow (p‚āÄ : CPN 4) (sh : KTorus) (s t : Sign) :
    (kOnticSetupFlow p‚āÄ sh).OutcomeRegion where
  ő© := kRegion ctx s t
  hő©_meas := kRegion_measurable ctx s t

/-- **SL-2: the singlet preparation on the `ő¶ ‚Č† id` sector.** The concrete
`LF3.PureSingletPreparation` for the two-qubit singlet over `kSectorDataFlow p‚āÄ sh`
(`ő¶ = kFlow sh ‚Č† id`). Identical to `ofK√§hlerPreparation` except the underlying
sector carries the genuine non-identity flow, so the scored event is
`preEvent = kFlow sh ‚ĀĽ¬Ļ' kRegion`. `bridge_op_p` holds because
`kMuPsi (kFlow sh ‚ĀĽ¬Ļ' kRegion) = kMuPsi (kRegion) = P_st` ‚ÄĒ the first equality is
`kFlow`'s Liouville-preservation (`kFlow_measurePreserving_muPsi`), now
load-bearing; the second is the carving identity `kMuPsi_kRegion`. -/
noncomputable def ofK√§hlerPreparationFlow
    (p‚āÄ : CPN 4) (sh : KTorus) (hgen : ‚ąÄ s t : Sign, 0 < P_st ctx.a ctx.b s t) :
    LF3.PureSingletPreparation (kSectorDataFlow p‚āÄ sh) ctx 4 :=
  LF3.PureSingletPreparation.ofHypothesis
    kMuPsi inferInstance
    (fubiniStudyMeasure p‚āÄ) inferInstance
    (kBridgeFlow p‚āÄ sh)
    (kPurePrepFlow p‚āÄ sh)
    (by decide)
    (kJED ctx hgen)
    (kOutcomeRegionFlow ctx p‚āÄ sh)
    (by
      intro s t
      show kMuPsi (kFlow sh ‚ĀĽ¬Ļ' kRegion ctx s t) = _
      rw [(kFlow_measurePreserving_muPsi sh).measure_preimage
            (kRegion_measurable ctx s t).nullMeasurableSet,
          kMuPsi_kRegion]
      congr 1
      symm
      rw [LF2.PurePreparation.born_rank_one_direct
            (kSectorDataFlow p‚āÄ sh) (fubiniStudyMeasure p‚āÄ) (kBridgeFlow p‚āÄ sh) kMuPsi
            (kPurePrepFlow p‚āÄ sh) ((kJED ctx hgen).eig s t) ((kJED ctx hgen).eig_unit s t)]
      exact kEig_born ctx hgen s t)

/-- The underlying sector genuinely carries `ő¶ ‚Č† id` (for any nonzero fibre shift),
via `kFlow_ne_id`. This is the SL-2 headline: the concrete ENTANGLED sector now
carries a genuine non-identity flow. -/
theorem ofK√§hlerPreparationFlow_phi_ne_id (p‚āÄ : CPN 4) {sh : KTorus} (hsh : sh ‚Č† 0) :
    (kSectorDataFlow p‚āÄ sh).toOntic.ő¶ ‚Č† id :=
  kFlow_ne_id p‚āÄ hsh

/-- The scored event of the flow preparation is the flow-pullback of the carved
region: `preEvent = kFlow sh ‚ĀĽ¬Ļ' kRegion`. So scoring trial `X n` on it reads
`X n ‚ĀĽ¬Ļ' preEvent = (kFlow sh ‚ąė X n) ‚ĀĽ¬Ļ' kRegion` ‚ÄĒ the microstate is evolved one
flow-step before its outcome block is checked. -/
lemma ofK√§hlerPreparationFlow_preEvent
    (p‚āÄ : CPN 4) (sh : KTorus) (hgen : ‚ąÄ s t : Sign, 0 < P_st ctx.a ctx.b s t)
    (s t : Sign) :
    ((ofK√§hlerPreparationFlow ctx p‚āÄ sh hgen).O_region s t).preEvent
      = kFlow sh ‚ĀĽ¬Ļ' kRegion ctx s t := rfl

/-! ### The load-bearing capstone: frequencies of flow-evolved singlet trials -/

open Filter Topology in
/-- **SL-2 capstone: the singlet frequencies survive the sector's own flow.** For
i.i.d. trials with the posited singlet fibre law `őľŌą`, the per-sector empirical
frequencies of the trials **evolved by the sector's non-identity flow**
`kFlow sh ‚Č† id` ‚ÄĒ i.e. of `(kFlow sh ‚ąė X) ‚ĀĽ¬Ļ' kRegion` ‚ÄĒ converge almost surely to
the Born weight `P_st ctx.a ctx.b s t`.

The deterministic flow `kFlow sh` is applied to every sampled microstate, and its
Liouville-preservation (`kFlow_measurePreserving_muPsi`) is exactly what keeps the
limit at `P_st` (via `bridge_op_p` / `weight_eq_P_st`). This is D1c-1's
load-bearing-flow achievement realised on the ENTANGLED singlet preparation.
Foundational-triple-only / Gleason-free. Standing gap unchanged: A5 (the entangled
sector is posited) and `kFlow` is dynamically trivial (a free fibre translation). -/
theorem ofK√§hlerPreparationFlow_flow_frequency_convergence
    (p‚āÄ : CPN 4) (sh : KTorus) (hgen : ‚ąÄ s t : Sign, 0 < P_st ctx.a ctx.b s t)
    {ő© : Type*} [MeasurableSpace ő©] {Pr : Measure ő©} [IsProbabilityMeasure Pr]
    {X : ‚Ąē ‚Üí ő© ‚Üí KSigma 4} (hX : ‚ąÄ n, Measurable (X n))
    (hlaw : ‚ąÄ n, Measure.map (X n) Pr = kMuPsi)
    (hindep : ‚ąÄ s t,
      Pairwise
        (Function.onFun
          (fun f g : ő© ‚Üí ‚ĄĚ => ProbabilityTheory.IndepFun f g Pr)
          (fun n =>
            Set.indicator ((kFlow sh ‚ąė X n) ‚ĀĽ¬Ļ' kRegion ctx s t) (fun _ => (1 : ‚ĄĚ))))) :
    ‚ąÄ s t, ‚ąÄŠĶź ŌČ ‚ąā Pr,
      Tendsto
        (fun M : ‚Ąē =>
          (‚ąĎ i ‚ąą Finset.range M,
              Set.indicator ((kFlow sh ‚ąė X i) ‚ĀĽ¬Ļ' kRegion ctx s t)
                (fun _ => (1 : ‚ĄĚ)) ŌČ) / (M : ‚ĄĚ))
        atTop
        (nhds (P_st ctx.a ctx.b s t)) := by
  intro s t
  have hind' : ‚ąÄ s t,
      Pairwise
        (Function.onFun (fun f g : ő© ‚Üí ‚ĄĚ => ProbabilityTheory.IndepFun f g Pr)
          (fun n =>
            Set.indicator
              (X n ‚ĀĽ¬Ļ' ((ofK√§hlerPreparationFlow ctx p‚āÄ sh hgen).O_region s t).preEvent)
              (fun _ => (1 : ‚ĄĚ)))) := fun s t => by
    simpa only [ofK√§hlerPreparationFlow_preEvent, ‚Üź Set.preimage_comp] using hindep s t
  have hconv := LF3.LF3_singlet_frequency_convergence
    (kSectorDataFlow p‚āÄ sh) ctx (ofK√§hlerPreparationFlow ctx p‚āÄ sh hgen) hX hlaw hind' s t
  simpa only [ofK√§hlerPreparationFlow_preEvent, ‚Üź Set.preimage_comp] using hconv

