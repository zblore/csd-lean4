variable (ctx : CSD.LF3.MeasurementContext)

/-! ### `kFlow` preserves the singlet fibre law `Œºœà` -/

/-- **The fibre flow preserves the singlet fibre law.** `kFlow sh` fixes the base
ray (so it preserves the Dirac `Œ¥_{[singlet]}` on `‚ÑÇ‚Ñô¬≥`) and translates the `T¬≤`
fibre (so it preserves the Haar volume there). This is the singlet analogue of
`kFlow_measurePreserving`, and the genuine Liouville content that makes `Œ¶`
load-bearing in the frequency capstone below. -/
theorem kFlow_measurePreserving_muPsi (sh : KTorus) :
    MeasurePreserving (kFlow (N := 4) sh) kMuPsi kMuPsi := by
  have h1 : MeasurePreserving (fun x : AddCircle (1 : ‚Ñù) => sh.1 + x)
      (volume : Measure (AddCircle (1 : ‚Ñù))) (volume : Measure (AddCircle (1 : ‚Ñù))) :=
    measurePreserving_add_left _ sh.1
  have h2 : MeasurePreserving (fun x : AddCircle (1 : ‚Ñù) => sh.2 + x)
      (volume : Measure (AddCircle (1 : ‚Ñù))) (volume : Measure (AddCircle (1 : ‚Ñù))) :=
    measurePreserving_add_left _ sh.2
  have htransl : MeasurePreserving (fun t : KTorus => sh + t)
      (volume : Measure KTorus) (volume : Measure KTorus) := h1.prod h2
  exact (MeasurePreserving.id (Measure.dirac singletRay)).prod htransl

/-! ### The preparation bundle over the `Œ¶ ‚âÝ id` sector

Each component of `ofK√§hlerPreparation` references the sector only through its
projection `œÄ = Prod.fst` and Liouville measure `ŒºL = kMuL p‚ÇÄ` ‚Äî both DEFINITIONALLY
equal between `kSectorData` and `kSectorDataFlow` (they differ only in `Œ¶`). So the
bridge / preparation / outcome-region proofs port verbatim. -/

/-- The axiom-free measure bridge for the `Œ¶ ‚âÝ id` sector (`c = 1`, `œÄ‚àóŒºL = ŒºFS`
via `Measure.fst_prod`), identical to `kBridge` ‚Äî the bridge does not see `Œ¶`. -/
noncomputable def kBridgeFlow (p‚ÇÄ : CPN 4) (sh : KTorus) :
    LF2.MeasureBridgeData (kSectorDataFlow p‚ÇÄ sh) (fubiniStudyMeasure p‚ÇÄ) where
  is_inv := fun U =>
    ‚ü®(continuous_const_smul U).measurable, fubiniStudyMeasure_smul_invariant U p‚ÇÄ‚ü©
  c := 1
  bridge_eq := by
    show Measure.map (kSectorDataFlow p‚ÇÄ sh).œÄ
        ((kSectorDataFlow p‚ÇÄ sh).ŒºL : Measure (KSigma 4)) = 1 ‚Ä¢ fubiniStudyMeasure p‚ÇÄ
    rw [one_smul]
    show Measure.map Prod.fst (kMuL p‚ÇÄ) = fubiniStudyMeasure p‚ÇÄ
    rw [kMuL, ‚Üê Measure.fst, Measure.fst_prod]

/-- The singlet `PurePreparation` over the `Œ¶ ‚âÝ id` sector (constant `rep`, Dirac
concentration through `œÄ = Prod.fst`), identical to `kPurePrep`. -/
noncomputable def kPurePrepFlow (p‚ÇÄ : CPN 4) (sh : KTorus) :
    LF2.PurePreparation (kSectorDataFlow p‚ÇÄ sh) kMuPsi 4 where
  œà := singletPsi
  unit_œà := singletPsi_norm
  rep := kRep
  hrep_unit := kRep_unit
  hrep_meas := kRep_meas
  ray_point := singletRay
  rep_at_ray := rfl
  push_dirac := by
    show Measure.map (kSectorDataFlow p‚ÇÄ sh).œÄ kMuPsi = Measure.dirac singletRay
    exact kMuPsi_push

/-- The per-sector outcome region over the `Œ¶ ‚âÝ id` ontic setup: same carved set
`kRegion` as `kOutcomeRegion` (the region is base-flow-agnostic). Its scored event
is `preEvent = kFlow sh ‚Åª¬π' kRegion` ‚Äî the flow enters HERE. -/
noncomputable def kOutcomeRegionFlow (p‚ÇÄ : CPN 4) (sh : KTorus) (s t : Sign) :
    (kOnticSetupFlow p‚ÇÄ sh).OutcomeRegion where
  Œ© := kRegion ctx s t
  hŒ©_meas := kRegion_measurable ctx s t

/-- **SL-2: the singlet preparation on the `Œ¶ ‚âÝ id` sector.** The concrete
`LF3.PureSingletPreparation` for the two-qubit singlet over `kSectorDataFlow p‚ÇÄ sh`
(`Œ¶ = kFlow sh ‚âÝ id`). Identical to `ofK√§hlerPreparation` except the underlying
sector carries the genuine non-identity flow, so the scored event is
`preEvent = kFlow sh ‚Åª¬π' kRegion`. `bridge_op_p` holds because
`kMuPsi (kFlow sh ‚Åª¬π' kRegion) = kMuPsi (kRegion) = P_st` ‚Äî the first equality is
`kFlow`'s Liouville-preservation (`kFlow_measurePreserving_muPsi`), now
load-bearing; the second is the carving identity `kMuPsi_kRegion`. -/
noncomputable def ofK√§hlerPreparationFlow
    (p‚ÇÄ : CPN 4) (sh : KTorus) (hgen : ‚àÄ s t : Sign, 0 < P_st ctx.a ctx.b s t) :
    LF3.PureSingletPreparation (kSectorDataFlow p‚ÇÄ sh) ctx 4 :=
  LF3.PureSingletPreparation.ofHypothesis
    kMuPsi inferInstance
    (fubiniStudyMeasure p‚ÇÄ) inferInstance
    (kBridgeFlow p‚ÇÄ sh)
    (kPurePrepFlow p‚ÇÄ sh)
    (by decide)
    (kJED ctx hgen)
    (kOutcomeRegionFlow ctx p‚ÇÄ sh)
    (by
      intro s t
      show kMuPsi (kFlow sh ‚Åª¬π' kRegion ctx s t) = _
      rw [(kFlow_measurePreserving_muPsi sh).measure_preimage
            (kRegion_measurable ctx s t).nullMeasurableSet,
          kMuPsi_kRegion]
      congr 1
      symm
      rw [LF2.PurePreparation.born_rank_one_direct
            (kSectorDataFlow p‚ÇÄ sh) (fubiniStudyMeasure p‚ÇÄ) (kBridgeFlow p‚ÇÄ sh) kMuPsi
            (kPurePrepFlow p‚ÇÄ sh) ((kJED ctx hgen).eig s t) ((kJED ctx hgen).eig_unit s t)]
      exact kEig_born ctx hgen s t)

/-- The underlying sector genuinely carries `Œ¶ ‚âÝ id` (for any nonzero fibre shift),
via `kFlow_ne_id`. This is the SL-2 headline: the concrete ENTANGLED sector now
carries a genuine non-identity flow. -/
theorem ofK√§hlerPreparationFlow_phi_ne_id (p‚ÇÄ : CPN 4) {sh : KTorus} (hsh : sh ‚âÝ 0) :
    (kSectorDataFlow p‚ÇÄ sh).toOntic.Œ¶ ‚âÝ id :=
  kFlow_ne_id p‚ÇÄ hsh

/-- The scored event of the flow preparation is the flow-pullback of the carved
region: `preEvent = kFlow sh ‚Åª¬π' kRegion`. So scoring trial `X n` on it reads
`X n ‚Åª¬π' preEvent = (kFlow sh ‚àò X n) ‚Åª¬π' kRegion` ‚Äî the microstate is evolved one
flow-step before its outcome block is checked. -/
lemma ofK√§hlerPreparationFlow_preEvent
    (p‚ÇÄ : CPN 4) (sh : KTorus) (hgen : ‚àÄ s t : Sign, 0 < P_st ctx.a ctx.b s t)
    (s t : Sign) :
    ((ofK√§hlerPreparationFlow ctx p‚ÇÄ sh hgen).O_region s t).preEvent
      = kFlow sh ‚Åª¬π' kRegion ctx s t := rfl

/-! ### The load-bearing capstone: frequencies of flow-evolved singlet trials -/

open Filter Topology in
/-- **SL-2 capstone: the singlet frequencies survive the sector's own flow.** For
i.i.d. trials with the posited singlet fibre law `Œºœà`, the per-sector empirical
frequencies of the trials **evolved by the sector's non-identity flow**
`kFlow sh ‚âÝ id` ‚Äî i.e. of `(kFlow sh ‚àò X) ‚Åª¬π' kRegion` ‚Äî converge almost surely to
the Born weight `P_st ctx.a ctx.b s t`.

The deterministic flow `kFlow sh` is applied to every sampled microstate, and its
Liouville-preservation (`kFlow_measurePreserving_muPsi`) is exactly what keeps the
limit at `P_st` (via `bridge_op_p` / `weight_eq_P_st`). This is D1c-1's
load-bearing-flow achievement realised on the ENTANGLED singlet preparation.
Foundational-triple-only / Gleason-free. Standing gap unchanged: A5 (the entangled
sector is posited) and `kFlow` is dynamically trivial (a free fibre translation). -/
theorem ofK√§hlerPreparationFlow_flow_frequency_convergence
    (p‚ÇÄ : CPN 4) (sh : KTorus) (hgen : ‚àÄ s t : Sign, 0 < P_st ctx.a ctx.b s t)
    {Œ© : Type*} [MeasurableSpace Œ©] {Pr : Measure Œ©} [IsProbabilityMeasure Pr]
    {X : ‚Ñï ‚Üí Œ© ‚Üí KSigma 4} (hX : ‚àÄ n, Measurable (X n))
    (hlaw : ‚àÄ n, Measure.map (X n) Pr = kMuPsi)
    (hindep : ‚àÄ s t,
      Pairwise
        (Function.onFun
          (fun f g : Œ© ‚Üí ‚Ñù => ProbabilityTheory.IndepFun f g Pr)
          (fun n =>
            Set.indicator ((kFlow sh ‚àò X n) ‚Åª¬π' kRegion ctx s t) (fun _ => (1 : ‚Ñù))))) :
    ‚àÄ s t, ‚àÄ·µê œâ ‚àÇ Pr,
      Tendsto
        (fun M : ‚Ñï =>
          (‚àë i ‚àà Finset.range M,
              Set.indicator ((kFlow sh ‚àò X i) ‚Åª¬π' kRegion ctx s t)
                (fun _ => (1 : ‚Ñù)) œâ) / (M : ‚Ñù))
        atTop
        (nhds (P_st ctx.a ctx.b s t)) := by
  intro s t
  have hind' : ‚àÄ s t,
      Pairwise
        (Function.onFun (fun f g : Œ© ‚Üí ‚Ñù => ProbabilityTheory.IndepFun f g Pr)
          (fun n =>
            Set.indicator
              (X n ‚Åª¬π' ((ofK√§hlerPreparationFlow ctx p‚ÇÄ sh hgen).O_region s t).preEvent)
              (fun _ => (1 : ‚Ñù)))) := fun s t => by
    simpa only [ofK√§hlerPreparationFlow_preEvent, ‚Üê Set.preimage_comp] using hindep s t
  have hconv := LF3.LF3_singlet_frequency_convergence
    (kSectorDataFlow p‚ÇÄ sh) ctx (ofK√§hlerPreparationFlow ctx p‚ÇÄ sh hgen) hX hlaw hind' s t
  simpa only [ofK√§hlerPreparationFlow_preEvent, ‚Üê Set.preimage_comp] using hconv

